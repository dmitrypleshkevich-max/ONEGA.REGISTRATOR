{
  "container": {
    "masks": [
      { "regex": "^(\\d{3})(00)(\\d{3})$", "desc": "Стандарт: 3 товара + 00 + 3 кол-во" },
      { "regex": "^[A-Z]{3}-\\d{5}$", "desc": "Альтернатива: ABC-12345" }
    ],
    "errorMessage": "Неверный формат контейнера. Допустимые форматы: 11100234 или ABC-12345"
  },
  "sscc": {
    "masks": [
      { "regex": "^00\\d{3}$", "desc": "Короткий SSCC" },
      { "regex": "^\\d{18}$", "desc": "Стандартный SSCC (18 цифр)" }
    ],
    "errorMessage": "Неверный формат SSCC."
  }
}
